{
  "name": "cc-moodboard",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "db:init": "bun run src/db/schema.ts",
    "build:css": "bunx tailwindcss -i public/input.css -o public/styles.css --minify"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "discord.js": "^14.14.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "tailwindcss": "^3.4.0"
  }
}
